root = true

# ============================================================================
# Default settings for all files
# ============================================================================
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# ============================================================================
# Python
# ============================================================================
[*.py]
indent_style = space
indent_size = 4
max_line_length = 88

# ============================================================================
# Markdown (do not trim whitespace — it breaks formatting)
# ============================================================================
[*.md]
trim_trailing_whitespace = false

# ============================================================================
# YAML / TOML / JSON
# ============================================================================
[*.{yml,yaml,toml,json}]
indent_style = space
indent_size = 2

# ============================================================================
# Shell scripts
# ============================================================================
[*.sh]
indent_style = space
indent_size = 2

# ============================================================================
# Windows scripts
# ============================================================================
[*.{bat,cmd,ps1}]
end_of_line = crlf

# ============================================================================
# Generated Qt files (avoid formatting fights)
# ============================================================================
[ui_*.py]
indent_style = space
indent_size = 4
